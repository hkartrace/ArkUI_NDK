+template<typename T>
+const char* GetCtorSignature()
+{
+    if (std::is_same<T, int>::value) {
+        return "I:V";
+    } else if (std::is_same<T, double>::value) {
+        return "D:V";
+    } else if (std::is_same<T, long>::value) {
+        return "J:V";
+    } else {
+        return nullptr;
+    }
+}
