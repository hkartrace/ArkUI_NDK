+const char* GetClassName()
+{
+    if (std::is_same<T, int>::value) {
+        return "Lstd/core/Int;";
+    } else if (std::is_same<T, double>::value) {
+        return "Lstd/core/Double;";
+    } else if (std::is_same<T, long>::value) {
+        return "Lstd/core/Long;";
+    } else {
+        return nullptr;
+    }
+}
