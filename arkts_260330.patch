+def _patch_file(file_path, replacements):
+    with open(file_path, "r", encoding="utf-8") as file:
+        content = file.read()
+
+    changed = False
+    for old, new in replacements:
+        content, replaced = _replace_once(content, old, new, file_path)
+        changed = changed or replaced
