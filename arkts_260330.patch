+std::string AniWindowUtils::ANIStringToStdString(ani_env *env, ani_string ani_str)
+{
+    ani_size sz {};
+    env->String_GetUTF8Size(ani_str, &sz);
+
+    std::string result(sz + 1, 0);
+    env->String_GetUTF8(ani_str, result.data(), result.size(), &sz);
+    result.resize(sz);
+    return result;
+}
