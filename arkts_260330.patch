+
+int32_t AniUtils::CreateNonBootRuntimeLinker(ani_env* env, const std::string &modulePath, ani_object& result)
+{
+    auto state = ANI_OK;
+    ani_string ani_str;
+    state = env->String_NewUTF8(modulePath.c_str(), modulePath.size(), &ani_str);
+    if (state != ANI_OK) {
+        HILOGE("String_NewUTF8 modulePath Failed");
+        return static_cast<int32_t>(state);
+    }
+    ani_ref undefined_ref;
+    state = env->GetUndefined(&undefined_ref);
+    if (state != ANI_OK) {
+        HILOGE("GetUndefined failed");
+        return static_cast<int32_t>(state);
+    }
+    ani_array refArray;
+    state = env->Array_New(1, undefined_ref, &refArray);
+    if (state != ANI_OK) {
+        HILOGE("Array_New_Ref Failed");
+        return static_cast<int32_t>(state);
+    }
+    state = env->Array_Set(refArray, 0, ani_str);
+    if (state != ANI_OK) {
+        HILOGE("Array_Set_Ref Failed");
+        return static_cast<int32_t>(state);
+    }
+    ani_class cls = nullptr;
+    state = env->FindClass("std.core.AbcRuntimeLinker", &cls);
+    if (state != ANI_OK) {
+        HILOGE("FindClass AbcRuntimeLinker failed");
+        return static_cast<int32_t>(state);
+    }
+    ani_method method = nullptr;
+    state = env->Class_FindMethod(cls, "<ctor>", "C{std.core.RuntimeLinker}C{std.core.Array}:", &method);
+    if (state != ANI_OK) {
+        HILOGE("Class_FindMethod ctor failed");
+        return static_cast<int32_t>(state);
+    }
+    state = env->Object_New(cls, method, &result, undefined_ref, refArray);
+    if (state != ANI_OK) {
+        HILOGE("Object_New AbcRuntimeLinker failed");
+        return static_cast<int32_t>(state);
+    }
+    return static_cast<int32_t>(ANI_OK);
+}
+}
