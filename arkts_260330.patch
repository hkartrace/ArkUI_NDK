+def _replace_once(content, old, new, file_path):
+    if new in content:
+        return content, False
+    variants = old if isinstance(old, (tuple, list)) else (old,)
+    for variant in variants:
+        if variant in content:
+            return content.replace(variant, new, 1), True
+    print(f"Warning: expected snippet not found in {file_path}, skipping", file=sys.stderr)
+    return content, False
