+bool GlfwRenderContext::CreateRenderingContext()
+{
+    if (!isVisible_) {
+        return false;
+    }
+    if (renderingWindow_ != nullptr) {
+        return true;
+    }
+
+    glfwWindowHint(GLFW_VISIBLE, GLFW_FALSE);
